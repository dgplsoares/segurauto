# Copie para .env e ajuste. O modo padrão (fakes + LLM stub) roda sem segredos.

# ---- App ----
ENVIRONMENT=local
LOG_LEVEL=INFO

# ---- Banco (Postgres + pgvector) ----
POSTGRES_USER=segurauto
POSTGRES_PASSWORD=segurauto
POSTGRES_DB=segurauto
DATABASE_URL=postgresql+asyncpg://segurauto:segurauto@db:5432/segurauto

# ---- Seams de integração — fake default / real opt-in (DEC-ORB-001/006/014) ----
USE_FAKE_CRM=1
USE_FAKE_ADS=1

# ---- LLM — stub determinístico default; OpenAI opt-in (DEC-ORB-006/008) ----
LLM_PROVIDER=stub
OPENAI_API_KEY=

# ---- Frontend (BFF → ai-service) ----
AI_SERVICE_URL=http://ai-service:8000
