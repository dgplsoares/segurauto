# Copie para .env e ajuste. O modo padrão (fakes + LLM stub) roda sem segredos.

# ---- App ----
# ENVIRONMENT=local monta a eval API da jornada, ecoa o OTP nos logs e usa um auth_pepper de dev.
ENVIRONMENT=local
LOG_LEVEL=INFO
# Liga a jornada de avaliação FORA de local (deploy público) — fail-closed por padrão; dados são fakes.
ENABLE_EVAL_API=false

# ---- Banco (Postgres + pgvector) ----
POSTGRES_USER=segurauto
POSTGRES_PASSWORD=segurauto
POSTGRES_DB=segurauto
DATABASE_URL=postgresql+asyncpg://segurauto:segurauto@db:5432/segurauto

# ---- Seams de integração — fake default / real opt-in (DEC-ORB-001/006/014) ----
USE_FAKE_CRM=1
USE_FAKE_ADS=1

# ---- LLM — stub determinístico default; provider real opt-in (DEC-ORB-006/008/046) ----
# LLM_PROVIDER: stub (default, sem segredos) | openai | anthropic. Se o provider real falhar (incidente ou
# saldo esgotado), a app degrada para o comportamento determinístico (a cotação/handoff seguem funcionando).
LLM_PROVIDER=stub
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Modelos (override p/ custo). Anthropic default = claude-opus-4-8; use claude-haiku-4-5 para baratear a conversa.
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-opus-4-8

# ---- E-mail (SMTP genérico — DEC-ORB-047) ----
# O provider de e-mail é INFRA trocável: a app só fala SMTP, nunca depende do fornecedor. Trocar de provider
# = mudar estas vars, ZERO código. Fake por padrão (não envia; loga o destino mascarado; OTP ecoado em local).
# Em deploy real: USE_FAKE_NOTIFICATIONS=0 + preencha o SMTP do seu provider + um MAIL_FROM cujo domínio esteja
# VERIFICADO no provider (DKIM/SPF). SMTP_SSL=1 → porta 465 (TLS implícito); SMTP_SSL=0 → porta 587 (STARTTLS).
USE_FAKE_NOTIFICATIONS=1
SMTP_HOST=
SMTP_PORT=465
SMTP_SSL=1
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=SegurAuto <noreply@example.com>
MAIL_BCC=

# ---- Frontend (BFF → ai-service) ----
AI_SERVICE_URL=http://ai-service:8000
# Indexação por buscadores: default OFF (noindex/robots disallow) — o remoto é HOMOLOG. Ligue só na prod real.
ALLOW_INDEXING=false
