# Copie para .env e ajuste. O modo padrão (fakes + LLM stub) roda sem segredos.

# ---- App ----
ENVIRONMENT=local
LOG_LEVEL=INFO

# ---- Banco (Postgres + pgvector) ----
POSTGRES_USER=segurauto
POSTGRES_PASSWORD=segurauto
POSTGRES_DB=segurauto
DATABASE_URL=postgresql+asyncpg://segurauto:segurauto@db:5432/segurauto

# ---- Seams de integração — fake default / real opt-in (DEC-ORB-001/006/014) ----
USE_FAKE_CRM=1
USE_FAKE_ADS=1

# ---- LLM — stub determinístico default; provider real opt-in (DEC-ORB-006/008/046) ----
# LLM_PROVIDER: stub (default, sem segredos) | openai | anthropic. Se o provider real falhar (incidente ou
# saldo esgotado), a app degrada para o comportamento determinístico (a cotação/handoff seguem funcionando).
LLM_PROVIDER=stub
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Modelos (override p/ custo). Anthropic default = claude-opus-4-8; use claude-haiku-4-5 para baratear a conversa.
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-opus-4-8

# ---- Frontend (BFF → ai-service) ----
AI_SERVICE_URL=http://ai-service:8000
